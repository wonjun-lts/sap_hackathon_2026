{
  "name": "bookoverview",
  "version": "0.0.1",
  "description": "書籍サマリ管理アプリ",
  "keywords": [
    "ui5",
    "openui5",
    "sapui5"
  ],
  "main": "webapp/index.html",
  "dependencies": {},
  "devDependencies": {
    "@ui5/cli": "^4.0.33",
    "@sap/ux-ui5-tooling": "1",
    "@sap-ux/eslint-plugin-fiori-tools": "^10.0.0",
    "eslint": "^10"
  },
  "scripts": {
    "deploy-config": "npx -p @sap/ux-ui5-tooling fiori add deploy-config cf",
    "build": "ui5 build --config=ui5.yaml --clean-dest --dest dist",
    "build:cf": "ui5 build --config=ui5.yaml --clean-dest --dest dist && cp xs-app.json dist/ && cd dist && zip -r cloversfioribookoverview.zip ."
  }
}